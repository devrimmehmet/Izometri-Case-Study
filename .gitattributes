# Normalize line endings on commit so shell scripts and configs
# are always stored as LF in the repository — regardless of the
# developer's core.autocrlf setting.
#
# Without this, Windows users with core.autocrlf=true would check out
# *.sh files with CRLF, and the keycloak-setup Alpine container would
# see \r in variable values, breaking every curl call.

* text=auto

# Force LF for files that run inside Linux containers or CI
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
*.md        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.vue       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.slnx      text eol=lf
*.xml       text eol=lf
*.conf      text eol=lf
*.sql       text eol=lf
*.ps1       text eol=lf

# Binary files — never convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.lock      text eol=lf
