# Copy this file to `.env` or use these keys as CI/CD secrets.
# Do not commit real secret values.

# JWT
JWT_ISSUER=Izometri.CaseStudy
JWT_AUDIENCE=Izometri.CaseStudy
JWT_SECRET=replace-with-at-least-32-character-secret
JWT_AUTHORITY=
JWT_PUBLIC_AUTHORITY=
JWT_REQUIRE_HTTPS_METADATA=false
AUTHENTICATION_ENABLE_LOCAL_LOGIN=false

# PostgreSQL
EXPENSE_DB_CONNECTION=Host=expense-db;Port=5432;Database=expense_db;Username=expense_user;Password=replace-with-expense-db-password
NOTIFICATION_DB_CONNECTION=Host=notification-db;Port=5432;Database=notification_db;Username=notification_user;Password=replace-with-notification-db-password

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=expense_app
RABBITMQ_PASSWORD=replace-with-rabbitmq-password

# Mail
MAIL_FROM_NAME=Izometri Expense
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=smtp-user@example.com
MAIL_PASSWORD=replace-with-smtp-password
MAIL_USE_SSL=true
MAIL_USE_PICKUP_FOLDER=false
MAIL_IGNORE_CERTIFICATE_ERRORS=false
MAIL_PICKUP_FOLDER_PATH=App_Data/mail-drop

# Netgsm
NETGSM_USERCODE=8500000000
NETGSM_PASSWORD=replace-with-netgsm-api-password
NETGSM_MSGHEADER=APPNAME
NETGSM_BASEURL=https://api.netgsm.com.tr
NETGSM_ENCODING=TR
NETGSM_APPNAME=IzometriCase
NETGSM_USE_OTP_ENDPOINT=false

# Live tests
RUN_LIVE_DELIVERY_TESTS=0
LIVE_NETGSM_SEND_SMS=0
LIVE_NETGSM_USERCODE=8500000000
LIVE_NETGSM_PASSWORD=replace-with-netgsm-api-password
LIVE_NETGSM_MSGHEADER=APPNAME
LIVE_MAIL_HOST=localhost
LIVE_MAIL_PORT=1025
LIVE_MAIL_USERNAME=
LIVE_MAIL_PASSWORD=
LIVE_MAIL_USE_SSL=false
LIVE_MAIL_VERIFY_MAILPIT=true
