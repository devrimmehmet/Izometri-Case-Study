{
  "info": {
    "name": "Izometri Case Study",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "expenseBaseUrl", "value": "http://localhost:5001" },
    { "key": "notificationBaseUrl", "value": "http://localhost:5002" },
    { "key": "token", "value": "" },
    { "key": "expenseId", "value": "" }
  ],
  "item": [
    {
      "name": "Login Personnel",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{expenseBaseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"personel@demo.com\",\n  \"password\": \"Pass123!\",\n  \"tenantCode\": \"acme\"\n}"
        }
      }
    },
    {
      "name": "Create Expense",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Correlation-Id", "value": "postman-create-expense" }
        ],
        "url": "{{expenseBaseUrl}}/api/expenses",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"category\": \"Travel\",\n  \"currency\": \"TRY\",\n  \"amount\": 3500,\n  \"description\": \"İstanbul müşteri toplantısı için ulaşım gideri\"\n}"
        }
      }
    },
    {
      "name": "Submit Expense",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{expenseBaseUrl}}/api/expenses/{{expenseId}}/submit"
      }
    },
    {
      "name": "Login HR",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{expenseBaseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"devrimmehmet@msn.com\",\n  \"password\": \"Pass123!\",\n  \"tenantCode\": \"acme\"\n}"
        }
      }
    },
    {
      "name": "Approve Expense",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{expenseBaseUrl}}/api/expenses/{{expenseId}}/approve"
      }
    },
    {
      "name": "Reject Expense",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{expenseBaseUrl}}/api/expenses/{{expenseId}}/reject",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Belge açıklaması yeterli değil\"\n}"
        }
      }
    },
    {
      "name": "List Expenses",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{expenseBaseUrl}}/api/expenses?pageNumber=1&pageSize=20"
      }
    },
    {
      "name": "List Notifications",
      "request": {
        "method": "GET",
        "url": "{{notificationBaseUrl}}/api/notifications"
      }
    },
    {
      "name": "List Outbox Dead Letters",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{expenseBaseUrl}}/api/admin/outbox/dead-letters"
      }
    },
    {
      "name": "Expense Health",
      "request": {
        "method": "GET",
        "url": "{{expenseBaseUrl}}/health"
      }
    },
    {
      "name": "Notification Health",
      "request": {
        "method": "GET",
        "url": "{{notificationBaseUrl}}/health"
      }
    }
  ]
}
