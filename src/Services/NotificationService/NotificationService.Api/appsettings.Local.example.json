{
  "ConnectionStrings": {
    "NotificationDb": "Host=localhost;Port=15434;Database=notification_db;Username=notification_user;Password=replace-with-notification-db-password"
  },
  "Jwt": {
    "Issuer": "Izometri.CaseStudy",
    "Audience": "Izometri.CaseStudy",
    "Secret": "replace-with-at-least-32-character-secret",
    "ExpirationMinutes": 30,
    "Authority": null,
    "PublicAuthority": null,
    "RequireHttpsMetadata": false
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5673,
    "UserName": "expense_app",
    "Password": "replace-with-rabbitmq-password"
  },
  "ExpenseService": {
    "BaseUrl": "http://localhost:5001"
  },
  "Authentication": {
    "EnableLocalLogin": false
  },
  "Mail": {
    "FromName": "Izometri Expense",
    "FromEmail": "no-reply@example.com",
    "Host": "smtp.example.com",
    "Port": 587,
    "UserName": "smtp-user@example.com",
    "Password": "replace-with-smtp-password",
    "UseSsl": true,
    "UsePickupFolder": false,
    "IgnoreCertificateErrors": false,
    "TimeoutSeconds": 15,
    "PickupFolderPath": "App_Data/mail-drop"
  },
  "Netgsm": {
    "UserCode": "8500000000",
    "Password": "replace-with-netgsm-api-password",
    "MsgHeader": "APPNAME",
    "BaseUrl": "https://api.netgsm.com.tr",
    "Encoding": "TR",
    "AppName": "IzometriCase",
    "UseOtpEndpoint": false
  }
}
